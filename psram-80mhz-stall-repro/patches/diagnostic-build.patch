+// DIAGNOSTIC: scan the whole heap for corruption and report. Used to bisect the old-logs
+// boot loop -- the first "CORRUPT" pinpoints the step that trashed the heap.
+static bool s_lv_ready = false;   // lv_init() done -> lv_mem_test is safe to call
+static void HEAPCHK(const char* where) {
+  bool ok = heap_caps_check_integrity_all(false);     // IDF heaps (internal + PSRAM)
+  const char* lv = s_lv_ready ? (lv_mem_test() == LV_RES_OK ? "ok" : "*CORRUPT*") : "n/a";
+  lv_mem_monitor_t mon{};
+  if (s_lv_ready) lv_mem_monitor(&mon);
+  Serial.printf("[HEAPCHK] %-26s heap=%s lvpool=%s free=%u stackHWM=%u | lvpool free=%u biggest=%u used=%u%%\n",
+                where, ok ? "ok" : "*CORRUPT*", lv,
+                (unsigned)heap_caps_get_free_size(MALLOC_CAP_INTERNAL),
+                (unsigned)uxTaskGetStackHighWaterMark(NULL),
+                (unsigned)mon.free_size, (unsigned)mon.free_biggest_size, (unsigned)mon.used_pct);
+  Serial.flush();
+}
